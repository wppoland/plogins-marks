msgid "Translations"
msgstr "Tłumaczenia"

#. Found in description header.
msgid "External Services"
msgstr "Usługi zewnętrzne"

#. Found in description header.
msgid "Sale &amp; Stock Badges PRO"
msgstr "Sale &amp; Stock Badges PRO"

