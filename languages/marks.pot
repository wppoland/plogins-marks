#. Description of the plugin
#: marks.php
msgid "Automatic and manual product badges for WooCommerce (sale, new, low-stock, bestseller) — CSS-only, no layout shift"
msgstr ""

#. Author of the plugin
#: marks.php
msgid "WPPoland"
msgstr ""

#. Author URI of the plugin
#: marks.php
msgid "https://plogins.com/"
msgstr ""

#: marks.php:47
msgid "Marks requires WooCommerce to be active."
msgstr ""

#: src/Admin/Settings.php:72
msgid "Marks Settings"
msgstr ""

#: src/Admin/Settings.php:123
msgid "Product badges that boost conversions"
msgstr ""

#: src/Admin/Settings.php:125
msgid "Badges highlight what makes a product worth buying — a sale, a fresh arrival, low stock or a bestseller. They are pure CSS, so they load instantly and never shift your layout. Configure them below; the live preview on the right updates as you type."
msgstr ""

#: src/Admin/Settings.php:136
msgid "Display"
msgstr ""

#: src/Admin/Settings.php:141
msgid "Enable badges"
msgstr ""

#: src/Admin/Settings.php:142
msgid "The master switch. When off, no badges render anywhere on your storefront and the badge stylesheet is not loaded — zero front-end impact."
msgstr ""

#: src/Admin/Settings.php:153
msgid "Show product badges on the storefront."
msgstr ""

#: src/Admin/Settings.php:160
msgid "Single product page"
msgstr ""

#: src/Admin/Settings.php:161
msgid "Show badges on the product page."
msgstr ""

#: src/Admin/Settings.php:163
msgid "Places badges over the main product image on each product's own page."
msgstr ""

#: src/Admin/Settings.php:167
msgid "Shop and category listings"
msgstr ""

#: src/Admin/Settings.php:168
msgid "Show badges on shop, category and tag listings."
msgstr ""

#: src/Admin/Settings.php:170
msgid "Places badges on product thumbnails across the shop, category and tag archive pages."
msgstr ""

#. translators: %s: shortcode wrapped in <code>.
#: src/Admin/Settings.php:179
#, php-format
msgid "Need badges somewhere else? Drop %s into any page, post or widget to render the current product's badges."
msgstr ""

#: src/Admin/Settings.php:187
msgid "Automatic badges"
msgstr ""

#: src/Admin/Settings.php:189
msgid "These appear on their own based on each product's live state — no manual tagging needed. Tick the ones you want and, optionally, give them your own wording. Leave a label blank to use the translated default."
msgstr ""

#: src/Admin/Settings.php:194
#: src/Admin/Settings.php:363
#: src/Service/MarksService.php:43
msgid "Sale"
msgstr ""

#: src/Admin/Settings.php:194
msgid "On products currently on sale."
msgstr ""

#: src/Admin/Settings.php:194
msgid "Shown automatically whenever a product has an active sale price."
msgstr ""

#: src/Admin/Settings.php:195
#: src/Admin/Settings.php:364
#: src/Service/MarksService.php:44
msgid "New"
msgstr ""

#: src/Admin/Settings.php:195
msgid "On products created within the newness window."
msgstr ""

#: src/Admin/Settings.php:195
msgid "Shown while a product is younger than the \"Newness window\" set under Thresholds."
msgstr ""

#: src/Admin/Settings.php:196
#: src/Admin/Settings.php:365
#: src/Service/MarksService.php:45
msgid "Low stock"
msgstr ""

#: src/Admin/Settings.php:196
msgid "On stock-managed products at or below the threshold."
msgstr ""

#: src/Admin/Settings.php:196
msgid "Creates urgency. Requires WooCommerce stock management; triggers at or below the \"Low-stock threshold\"."
msgstr ""

#: src/Admin/Settings.php:197
#: src/Service/MarksService.php:46
msgid "Bestseller"
msgstr ""

#: src/Admin/Settings.php:197
msgid "On products at or above the sales threshold."
msgstr ""

#: src/Admin/Settings.php:197
msgid "Social proof for your top sellers. Triggers once total units sold reaches the \"Bestseller threshold\"."
msgstr ""

#: src/Admin/Settings.php:198
#: src/Service/MarksService.php:47
msgid "Free shipping"
msgstr ""

#: src/Admin/Settings.php:198
msgid "On products in a free-shipping shipping class."
msgstr ""

#: src/Admin/Settings.php:198
msgid "Shown for products whose shipping class matches one listed under \"Free-shipping classes\"."
msgstr ""

#: src/Admin/Settings.php:199
#: src/Service/MarksService.php:48
msgid "Out of stock"
msgstr ""

#: src/Admin/Settings.php:199
msgid "On products that are out of stock."
msgstr ""

#: src/Admin/Settings.php:199
msgid "Sets expectations before the click. Shown when WooCommerce reports the product as out of stock."
msgstr ""

#: src/Admin/Settings.php:201
msgid "Discount percent"
msgstr ""

#: src/Admin/Settings.php:201
msgid "Shows the sale discount as a percentage (e.g. -20%)."
msgstr ""

#: src/Admin/Settings.php:201
msgid "Calculates the saving from the regular and sale price automatically, e.g. -20%. Pairs well with — or instead of — the plain Sale badge."
msgstr ""

#: src/Admin/Settings.php:204
msgid "Hide theme “Sale!” flash"
msgstr ""

#: src/Admin/Settings.php:205
msgid "Replace WooCommerce’s default sale flash with the Marks sale badge only."
msgstr ""

#: src/Admin/Settings.php:207
msgid "Avoids two sale labels on one product card. Marks badges are CSS-only — they never reflow the page. Best used together with the Sale badge above."
msgstr ""

#: src/Admin/Settings.php:215
msgid "Thresholds"
msgstr ""

#: src/Admin/Settings.php:217
msgid "Tune when the automatic badges above trigger. Values must be at least 1."
msgstr ""

#: src/Admin/Settings.php:222
msgid "Newness window (days)"
msgstr ""

#: src/Admin/Settings.php:222
msgid "Show the New badge on products created within this many days."
msgstr ""

#: src/Admin/Settings.php:222
msgid "A product counts as \"new\" for this many days after it is published. 30 is a sensible default."
msgstr ""

#: src/Admin/Settings.php:223
msgid "Low-stock threshold"
msgstr ""

#: src/Admin/Settings.php:223
msgid "Show the Low stock badge when remaining stock is at or below this number."
msgstr ""

#: src/Admin/Settings.php:223
msgid "When stock falls to this number or below, the Low stock badge appears. Lower it to reserve the badge for true scarcity."
msgstr ""

#: src/Admin/Settings.php:224
msgid "Bestseller threshold"
msgstr ""

#: src/Admin/Settings.php:224
msgid "Show the Bestseller badge when total sales reach this number."
msgstr ""

#: src/Admin/Settings.php:224
msgid "Total lifetime units sold needed to earn the Bestseller badge. Set it to match what \"popular\" means for your store."
msgstr ""

#: src/Admin/Settings.php:228
msgid "Free-shipping classes"
msgstr ""

#: src/Admin/Settings.php:229
msgid "Enter the slugs of your WooCommerce shipping classes that ship free, separated by commas. Find slugs under WooCommerce → Settings → Shipping → Classes."
msgstr ""

#: src/Admin/Settings.php:240
msgid "Comma-separated product shipping-class slugs that count as free shipping."
msgstr ""

#: src/Admin/Settings.php:248
msgid "Appearance"
msgstr ""

#: src/Admin/Settings.php:253
msgid "Badge shape"
msgstr ""

#: src/Admin/Settings.php:254
msgid "Pill gives soft, fully-rounded corners; Square gives a tighter, more editorial look. Themes can override the exact radius via the --marks-radius variable."
msgstr ""

#: src/Admin/Settings.php:261
msgid "Pill (rounded)"
msgstr ""

#: src/Admin/Settings.php:262
msgid "Square"
msgstr ""

#: src/Admin/Settings.php:274
msgid "Uppercase labels"
msgstr ""

#: src/Admin/Settings.php:274
msgid "Render badge labels in uppercase."
msgstr ""

#: src/Admin/Settings.php:274
msgid "Uppercases every badge label and adds light letter-spacing for a bolder, more uniform look."
msgstr ""

#: src/Admin/Settings.php:275
msgid "Max badges (product page)"
msgstr ""

#: src/Admin/Settings.php:275
msgid "Maximum number of badges shown on a single product page."
msgstr ""

#: src/Admin/Settings.php:275
msgid "Caps how many badges stack on a single product page so the image stays uncluttered. Highest-priority badges win."
msgstr ""

#: src/Admin/Settings.php:276
msgid "Max badges (listings)"
msgstr ""

#: src/Admin/Settings.php:276
msgid "Maximum number of badges shown on shop and category listings."
msgstr ""

#: src/Admin/Settings.php:276
msgid "Caps badges on the smaller thumbnails in shop and category grids. 2–3 keeps listings clean."
msgstr ""

#: src/Admin/Settings.php:283
msgid "Manual badge"
msgstr ""

#. translators: %s: meta key wrapped in <code>.
#: src/Admin/Settings.php:288
#, php-format
msgid "Define one store-wide badge (label + colour). Leave the label empty to disable it. To show it on a specific product, set the %s product meta — handy for \"Editor's pick\" or \"Staff favourite\" flags."
msgstr ""

#: src/Admin/Settings.php:297
msgid "Manual badge label"
msgstr ""

#: src/Admin/Settings.php:298
msgid "The text shown by your manual badge, e.g. \"Editor's pick\". Leave blank to turn the manual badge off entirely."
msgstr ""

#: src/Admin/Settings.php:307
msgid "e.g. Editor’s pick"
msgstr ""

#: src/Admin/Settings.php:313
msgid "Manual badge colour"
msgstr ""

#: src/Admin/Settings.php:314
msgid "Pick a semantic colour. Accent uses your store blue, Success green, Warning amber, Danger red, Neutral grey. Exact shades are themeable via the --marks-bg-* variables."
msgstr ""

#: src/Admin/Settings.php:356
msgid "Badge preview"
msgstr ""

#: src/Admin/Settings.php:357
msgid "Live preview"
msgstr ""

#: src/Admin/Settings.php:359
msgid "A sample of how your badges will look on a product image."
msgstr ""

#: src/Admin/Settings.php:368
msgid "No badges enabled yet — tick some on the left to see them here."
msgstr ""

#: src/Admin/Settings.php:385
msgid "Badges are not available yet"
msgstr ""

#: src/Admin/Settings.php:387
msgid "Marks could not load its badge engine. This usually means a required dependency is missing or out of date. Please reinstall or update the plugin; once the engine is present, this screen will show the full badge settings."
msgstr ""

